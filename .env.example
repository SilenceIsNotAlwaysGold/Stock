# ============================================================
# quant-platform-v8 Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Application ---
APP_NAME=quant-platform-v8
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
TIMEZONE=Asia/Shanghai

# --- PostgreSQL ---
PG_HOST=localhost
PG_PORT=5432
PG_USER=quant
PG_PASSWORD=quant123
PG_DATABASE=quant_v8

# --- MongoDB ---
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=admin
MONGO_PASSWORD=quant123
MONGO_DATABASE=quant_v8

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=quant123
REDIS_DB=0

# --- DeepSeek LLM ---
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- Data Sources ---
TUSHARE_TOKEN=your_tushare_token_here
TUSHARE_ENABLED=true

# --- Security ---
JWT_SECRET=your-secret-key-change-in-production

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# T1 Strategy
T1_TOP_N=5
T1_MARKET_SAFE_THRESHOLD=0.0
T1_MIN_TOTAL_SCORE=40.0
T1_SCAN_DAYS=30
